# ============================================================
# .env.example — Copy to `.env` and fill in your values.
# Voice AI Sidecar v2  |  Cloudflare Workers AI STT + TTS + Voice Commands
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO

# ── Sidecar Security ─────────────────────────────────────────
# .NET 10 backend must send this in the X-API-Key request header
API_KEY=change-me-to-a-strong-random-secret

# ── AI APIs ─────────────────────────────────────────────────
# Cloudflare Account ID và API Token cho Workers AI
# Lấy từ: https://dash.cloudflare.com/profile/api-tokens
# Account ID: https://dash.cloudflare.com/ (trong URL sau /accounts/)
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ── .NET 10 Backend ───────────────────────────────────────────
# Địa chỉ API server .NET 10
DOTNET_API_BASE_URL=http://localhost:5000
# API key để sidecar authenticate với .NET backend
DOTNET_API_KEY=change-me-dotnet-api-key
# Endpoint callback nhận STT result từ sidecar
DOTNET_VOICE_CALLBACK_PATH=/api/voicecommands/callback
